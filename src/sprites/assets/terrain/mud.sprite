[meta]
name = "mud"
width = 16
height = 16

[palette]
"#" = "#5C4033"
"@" = "#6B4912"
"." = "#8B6914"
"=" = "#7A5C2E"
"-" = "#4A3728"

[animations]
idle = { frames = [0], rate = 1 }

[frame.0]
art = """
#@.=-#@.=-#@.=-#
@#-=.@#-=.@#-=.
.=-#@.=-#@.=-#@.
=-@#-.=-@#-.=-@#
#@.=-#@.=-#@.=-#
@#-=.@#-=.@#-=.
.=-#@.=-#@.=-#@.
=-@#-.=-@#-.=-@#
#@.=-#@.=-#@.=-#
@#-=.@#-=.@#-=.
.=-#@.=-#@.=-#@.
=-@#-.=-@#-.=-@#
#@.=-#@.=-#@.=-#
@#-=.@#-=.@#-=.
.=-#@.=-#@.=-#@.
=-@#-.=-@#-.=-@#
"""
