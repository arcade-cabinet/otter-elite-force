@#=-@#=-@#=-@#=-
.=#@.=#@.=#@.=#@
=-@#=-@#=-@#=-@#
#@.=#@-=#@.=#@.=
@#=-@#=-@#=-@#=-
.=#@.=#@.=#@.=#@
=-@#=-@#=-@#=-@#
#@.=#@.=#@.=#@-=
@#=-@#=-@#=-@#=-
.=#@.=#@-=#@.=#@
=-@#=-@#=-@#=-@#
#@.=#@.=#@.=#@.=
@#=-@#=-@#=-@#=-
.=#@-=#@.=#@.=#@
=-@#=-@#=-@#=-@#
"""
