[meta]
name = "dirt"
width = 16
height = 16

[palette]
"#" = "#8B7355"
"@" = "#6B5B3E"
"." = "#A0926B"
"=" = "#C4B48C"
"-" = "#7A6B4E"

[animations]
idle = { frames = [0], rate = 1 }

[frame.0]
art = """
