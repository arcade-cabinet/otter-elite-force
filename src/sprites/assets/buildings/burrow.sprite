     ^++++^^^^^^^^++++^^
     ^++++^^^^^^^^++++^^
      ^+++^^^^^^^^^^+++^
       ^^^^^^^^^^^^^^^^^^
        ##@@@@@@@@@@@@##
        #@oooooooooooo@#
        #@oooooooooooo@#
        ##@@@@@@@@@@@@##
        ##@@@@####@@@@##
        ##@@@@####@@@@##
        ##@@@@#..#@@@@##
        ##@@@@#..#@@@@##
         @@@@@@..@@@@@@
          @@@@@@@@@@@@
     ^^^^^^^^^^^^^^^^^^^^^^^^
    ^^^^^^^^^^^^^^^^^^^^^^^^^^
   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^
   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^


"""
