  "objectives": [
    { "id": "capture-charlie",     "description": "Capture Hilltop Charlie",                     "type": "primary" },
    { "id": "capture-bravo",       "description": "Capture Hilltop Bravo",                       "type": "primary" },
    { "id": "capture-alpha",       "description": "Capture Hilltop Alpha",                       "type": "primary" },
    { "id": "hold-all-hilltops",   "description": "Hold all 3 hilltops for 3 minutes",           "type": "primary" },
    { "id": "bonus-no-buildings",  "description": "Capture all hilltops without losing a building","type": "bonus" }
  ],

  "phases": [
    {
      "id": "recon",
      "name": "Reconnaissance",
      "activeObjectives": ["capture-charlie"],
      "dialogue": [
        { "trigger": "timer", "delayMs": 5000,  "speaker": "Col. Bubbles", "text": "Three hilltops, Captain. Charlie is closest and least defended. Take it first to establish a forward position." },
        { "trigger": "timer", "delayMs": 15000, "speaker": "FOXHOUND",     "text": "Scale-Guard has dug in on all three hills. Flag posts mark their command points. Destroy them to capture." },
        { "trigger": "timer", "delayMs": 30000, "speaker": "Col. Bubbles", "text": "New tech for this operation: Mortar Otters for indirect fire, Gun Towers and Stone Walls for fortification. Use them." }
      ]
    },
    {
      "id": "assault-bravo",
      "name": "Assault Bravo",
      "activeObjectives": ["capture-bravo"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "capture-charlie" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Charlie secured. Bravo is next -- west side, across the river ford. Expect heavier resistance." },
        { "trigger": "phaseStart", "speaker": "FOXHOUND",     "text": "Bravo has gun emplacements. Use Mortar Otters to soften them before your infantry push." }
      ]
    },
    {
      "id": "assault-alpha",
      "name": "Assault Alpha",
      "activeObjectives": ["capture-alpha"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "capture-bravo" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND",     "text": "Alpha is the main position. Highest ground, most defenders, radio tower for reinforcement calls." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "This is the big push, Captain. Fortify Charlie and Bravo before you move on Alpha." }
      ]
    },
    {
      "id": "hold-the-line",
      "name": "Hold the Line",
      "activeObjectives": ["hold-all-hilltops"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "capture-alpha" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND",     "text": "All three hilltops secured! But Scale-Guard is massing for a counterattack. Hold all positions for three minutes." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Dig in, Captain. Build walls, towers, whatever you can. Here they come." }
      ],
      "waveDefense": {
        "waves": [
          { "delayMs": 30000,  "composition": [{ "type": "skink", "count": 6 }, { "type": "gator", "count": 3 }], "targetZone": "hilltop_charlie" },
          { "delayMs": 60000,  "composition": [{ "type": "gator", "count": 5 }, { "type": "viper", "count": 2 }], "targetZone": "hilltop_bravo" },
          { "delayMs": 90000,  "composition": [{ "type": "gator", "count": 4 }, { "type": "viper", "count": 3 }, { "type": "skink", "count": 4 }], "targetZone": "hilltop_alpha" },
          { "delayMs": 120000, "composition": [{ "type": "croc_champion", "count": 1 }, { "type": "gator", "count": 6 }], "targetZone": "hilltop_alpha" }
        ]
      }
    }
  ],

  "victoryDialogue": [
    { "speaker": "Col. Bubbles", "text": "All three firebases secure. Counterattack repelled. Outstanding defensive work, Captain." },
    { "speaker": "Gen. Whiskers", "text": "Firebase Delta is ours. The artillery advantage will be decisive in the operations ahead. Well done." }
  ],

