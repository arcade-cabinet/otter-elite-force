  "objectives": [
    { "id": "escort-convoy",      "description": "Escort all 3 convoy trucks to the extraction point",  "type": "primary" },
    { "id": "clear-ambush-2",     "description": "Clear the roadblock at the ravine",                   "type": "primary" },
    { "id": "clear-ambush-3",     "description": "Clear the ridge ambush position",                     "type": "primary" },
    { "id": "bonus-supply-cache", "description": "Discover the hidden supply cache",                    "type": "bonus" },
    { "id": "bonus-no-truck-lost","description": "Complete escort without losing any trucks",            "type": "bonus" }
  ],

  "phases": [
    {
      "id": "mustering",
      "name": "Mustering",
      "activeObjectives": ["escort-convoy"],
      "dialogue": [
        { "trigger": "timer", "delayMs": 5000,  "speaker": "Col. Bubbles", "text": "Captain, listen up. Three supply trucks need to reach Firebase Delta up north. The causeway is the only road, and Scale-Guard knows it." },
        { "trigger": "timer", "delayMs": 20000, "speaker": "FOXHOUND",     "text": "Intel shows at least three prepared ambush positions along the causeway. They've had days to dig in." },
        { "trigger": "timer", "delayMs": 45000, "speaker": "Col. Bubbles", "text": "When you're ready, move a unit north onto the causeway. The convoy will follow your lead." }
      ]
    },
    {
      "id": "first-contact",
      "name": "First Contact",
      "activeObjectives": ["escort-convoy"],
      "entryCondition": { "type": "zoneEnter", "zone": "causeway_south", "faction": "ura" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND", "text": "Convoy is rolling. Watch the treeline on the right -- heat signatures ahead." }
      ],
      "spawns": [
        { "trigger": "zoneEnter", "zone": "ambush_1", "units": [{ "type": "gator", "faction": "scale_guard", "x": 72, "y": 60, "count": 4 }, { "type": "skink", "faction": "scale_guard", "x": 80, "y": 58, "count": 2 }], "dialogue": { "speaker": "FOXHOUND", "text": "Ambush! Contacts from the treeline. Protect those trucks!" } }
      ]
    },
    {
      "id": "the-ravine",
      "name": "The Ravine",
      "activeObjectives": ["clear-ambush-2"],
      "entryCondition": { "type": "zoneEnter", "zone": "causeway_mid", "faction": "ura" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND",     "text": "Roadblock ahead. Log barricade across the causeway with dug-in defenders. You'll need to clear it." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Hit them hard, Captain. Every minute the convoy is stopped is a minute they can flank us." }
      ]
    },
    {
      "id": "the-ridge",
      "name": "The Ridge",
      "activeObjectives": ["clear-ambush-3"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "clear-ambush-2" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND",     "text": "Final ambush position ahead. Elevated ridge with ranged units and a mortar pit. This is the tough one." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Use your Shellcrackers to soak fire. Get close and take that ridge." }
      ]
    }
  ],

  "victoryDialogue": [
    { "speaker": "Col. Bubbles", "text": "All three trucks made it. Firebase Delta has its supplies. Outstanding escort work, Captain." },
    { "speaker": "FOXHOUND", "text": "Scale-Guard lost a lot of soldiers on that causeway. They won't try that route again anytime soon." }
  ],

