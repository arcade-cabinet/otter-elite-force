  "objectives": [
    { "id": "neutralize-lookout",  "description": "Neutralize the observation post",              "type": "primary" },
    { "id": "infiltrate-compound", "description": "Infiltrate the compound",                      "type": "primary" },
    { "id": "rescue-prisoner",     "description": "Rescue General Whiskers from the prison block", "type": "primary" },
    { "id": "extract",             "description": "Extract to the southern exfil zone",            "type": "primary" },
    { "id": "bonus-stealth",       "description": "Complete infiltration without triggering alarm", "type": "bonus" },
    { "id": "bonus-intel",         "description": "Recover intel documents from officer quarters",  "type": "bonus" }
  ],

  "phases": [
    {
      "id": "approach",
      "name": "Approach",
      "activeObjectives": ["neutralize-lookout"],
      "dialogue": [
        { "trigger": "timer", "delayMs": 3000,  "speaker": "Col. Bubbles", "text": "Listen up, Captain. General Whiskers is being held in a Scale-Guard detention compound. This is a commando operation -- no base, no reinforcements." },
        { "trigger": "timer", "delayMs": 12000, "speaker": "FOXHOUND",     "text": "Observation post on the east ridge. Two sentries. Take them out quietly and you'll have a clear approach to the compound." },
        { "trigger": "timer", "delayMs": 20000, "speaker": "Col. Bubbles", "text": "Two entry points: main gate on the south wall, or the drainage canal on the east side. The canal is quieter." }
      ]
    },
    {
      "id": "infiltration",
      "name": "Infiltration",
      "activeObjectives": ["infiltrate-compound"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "neutralize-lookout" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND", "text": "Lookout neutralized. Move to the compound. Watch for roaming patrols in the jungle." },
        { "trigger": "phaseStart", "speaker": "FOXHOUND", "text": "Main gate has two guards. Drainage canal on the east side is a stealth entry if you have a swimmer." }
      ]
    },
    {
      "id": "rescue",
      "name": "Rescue",
      "activeObjectives": ["rescue-prisoner"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "infiltrate-compound" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND",     "text": "You're inside. Prison block is northeast of your position. Guards heavy around the cells." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Get the General out alive, Captain. Everything depends on this." }
      ]
    },
    {
      "id": "extraction",
      "name": "Extraction",
      "activeObjectives": ["extract"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "rescue-prisoner" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "Gen. Whiskers", "text": "Captain... thank you. I have critical intelligence about Scale-Guard operations. We must get this to HQ." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles",  "text": "Exfil zone is south, past the jungle. Move fast -- they'll have the whole compound after you." }
      ],
      "spawns": [
        { "trigger": "phaseStart", "units": [{ "type": "gator", "faction": "scale_guard", "x": 40, "y": 30, "count": 4 }, { "type": "skink", "faction": "scale_guard", "x": 60, "y": 28, "count": 3 }], "dialogue": { "speaker": "FOXHOUND", "text": "Alarm triggered! Compound garrison mobilizing. Get out now!" } }
      ]
    }
  ],

  "victoryDialogue": [
    { "speaker": "Gen. Whiskers", "text": "Outstanding work, Captain. Scale-Guard had plans for a major offensive. With this intelligence, we can prepare." },
    { "speaker": "Col. Bubbles", "text": "General's safe. Chapter 1 complete. The real fight for the Copper-Silt Reach begins now." }
  ],

