  "phases": [
    {
      "id": "landfall",
      "name": "Landfall",
      "activeObjectives": ["gather-timber"],
      "dialogue": [
        { "trigger": "timer", "delayMs": 15000, "speaker": "FOXHOUND", "text": "Captain, you're on the ground. Mangrove grove to the northwest -- timber for construction. Get your workers moving." },
        { "trigger": "timer", "delayMs": 45000, "speaker": "Col. Bubbles", "text": "Priority one: establish resource flow. Harvest timber, haul it back to the lodge. We need materials before we can build anything." }
      ]
    },
    {
      "id": "base-building",
      "name": "Base Building",
      "activeObjectives": ["build-command-post", "build-barracks"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "gather-timber" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Good work, Captain. You've got materials. Build a Command Post for logistics -- that's your upgrade path. Then a Barracks for infantry." },
        { "trigger": "phaseStart", "speaker": "FOXHOUND", "text": "Command Post also unlocks Watchtowers and Fish Traps. You'll want both." }
      ],
      "spawns": [
        { "trigger": "timer", "delayMs": 300000, "units": [{ "type": "skink", "faction": "scale_guard", "x": 52, "y": 30, "count": 2 }], "dialogue": { "speaker": "FOXHOUND", "text": "Movement near the river, Captain. Scale-Guard scouts. They're not aggressive yet -- but they know this area." } }
      ]
    },
    {
      "id": "the-crossing",
      "name": "The Crossing",
      "activeObjectives": ["train-mudfoots", "repair-bridge", "cross-river"],
      "entryCondition": { "type": "allObjectivesComplete", "objectiveIds": ["build-command-post", "build-barracks"] },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Captain, we need to push north. The bridge crossing is our only path -- it's damaged but repairable." },
        { "trigger": "phaseStart", "speaker": "FOXHOUND", "text": "Send a worker to the bridge. They can patch it. But expect Scale-Guard resistance once you start work." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Train up some Mudfoots first. You'll want fighters before you start hammering." }
      ],
      "spawns": [
        { "trigger": "zoneEnter", "zone": "bridge_crossing", "unitType": "river_rat", "units": [{ "type": "gator", "faction": "scale_guard", "x": 60, "y": 28, "count": 4 }, { "type": "skink", "faction": "scale_guard", "x": 64, "y": 26, "count": 2 }], "dialogue": { "speaker": "Col. Bubbles", "text": "Contacts north of the bridge! Defend the workers!" } }
      ]
    },
    {
      "id": "clear-outpost",
      "name": "Clear the Outpost",
      "activeObjectives": ["destroy-outpost"],
      "entryCondition": { "type": "objectiveComplete", "objectiveId": "cross-river" },
      "dialogue": [
        { "trigger": "phaseStart", "speaker": "FOXHOUND", "text": "Enemy outpost ahead, northeast. Flag Post is their command structure -- destroy it and they'll scatter." },
        { "trigger": "phaseStart", "speaker": "Col. Bubbles", "text": "Take it out, Captain. That outpost is the last obstacle to securing this beachhead." }
      ]
    }
  ],

  "victoryDialogue": [
    { "speaker": "Gen. Whiskers", "text": "Outstanding work, Captain. Beachhead is secured. The Copper-Silt Reach campaign has begun." },
    { "speaker": "Col. Bubbles", "text": "Reinforcements and supplies inbound. Rest your troops -- the next push won't be this easy. HQ out." }
  ],

