{
	"name": "otter-elite-force",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"packageManager": "pnpm@10.26.2",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"build:analyze": "tsc && vite build --mode analyze",
		"preview": "vite preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:unit": "vitest run --reporter=verbose",
		"test:unit:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:browser": "vitest run --config vitest.browser.config.ts",
		"test:all": "pnpm test:unit && pnpm test:browser && pnpm test:e2e",
		"playwright:install": "playwright install --with-deps chromium"
	},
	"dependencies": {
		"@capacitor-community/sqlite": "^7.0.0",
		"@capacitor/android": "^8.2.0",
		"@capacitor/cli": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/ios": "^8.2.0",
		"@fontsource/black-ops-one": "^5.2.8",
		"@fontsource/share-tech-mono": "^5.2.7",
		"@fontsource/special-elite": "^5.2.8",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"bitecs": "^0.4.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"littlejsengine": "^1.18.0",
		"solid-js": "^1.9.12",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"tone": "^15.1.22",
		"tw-animate-css": "^1.4.0",
		"yuka": "^0.7.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@napi-rs/canvas": "^0.1.97",
		"@playwright/test": "^1.57.0",
		"@solidjs/testing-library": "^0.8.10",
		"@testing-library/dom": "^10.4.1",
		"@types/node": "^25.5.0",
		"@vitest/browser": "^4.1.1",
		"@vitest/browser-playwright": "^4.1.1",
		"@vitest/coverage-v8": "^4.0.16",
		"happy-dom": "^20.8.8",
		"playwright": "^1.58.2",
		"tsx": "^4.21.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.5",
		"vite-plugin-solid": "^2.11.11",
		"vitest": "^4.0.16"
	}
}
