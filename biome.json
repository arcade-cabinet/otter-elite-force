{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"src/**/*.ts",
			"src/**/*.tsx",
			"src/**/*.js",
			"src/**/*.json",
			"e2e/**/*",
			"scripts/**/*",
			"*.ts",
			"*.tsx",
			"*.js",
			"*.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/**/*.css"],
			"linter": { "enabled": false },
			"formatter": { "enabled": false }
		},
		{
			"includes": ["src/components/ui/**/*.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useFocusableInteractive": "off",
						"useSemanticElements": "off",
						"useAriaPropsForRole": "off",
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		},
		{
			"includes": ["src/ui/**/*.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/test/**/*.ts",
				"**/test/**/*.tsx",
				"**/__tests__/**/*.ts",
				"**/__tests__/**/*.tsx"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off",
						"noNonNullAssertedOptionalChain": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"correctness": {
						"noUnusedVariables": "warn",
						"noUnusedFunctionParameters": "off",
						"noUnsafeOptionalChaining": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all",
			"semicolons": "always"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
