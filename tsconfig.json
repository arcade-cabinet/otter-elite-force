{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,
		"types": ["vite/client"],

		/* JSX */
		"jsx": "react-jsx",

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,

		/* Paths */
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": [
		"src/main.tsx",
		"src/app",
		"src/game",
		"src/ui",
		"src/config",
		"src/ecs",
		"src/data",
		"src/systems/combatSystem.ts",
		"src/systems/economySystem.ts",
		"src/systems/productionSystem.ts",
		"src/systems/buildingSystem.ts",
		"src/systems/fogSystem.ts",
		"src/systems/syncSystem.ts",
		"src/systems/movementSystem.ts",
		"src/systems/orderSystem.ts",
		"src/systems/scenarioSystem.ts",
		"src/systems/stealthSystem.ts",
		"src/systems/waterSystem.ts",
		"src/systems/weatherSystem.ts",
		"src/systems/gameLoop.ts",
		"src/ai",
		"src/audio",
		"src/Scenes",
		"src/maps",
		"src/input",
		"src/persistence",
		"src/stores",
		"src/sprites/parser.ts",
		"src/sprites/compiler.ts",
		"src/sprites/atlas.ts",
		"src/sprites/types.ts",
		"src/scenarios",
		"src/types"
	],
	"exclude": ["src/**/*.test.ts", "src/**/__tests__/**"]
}
